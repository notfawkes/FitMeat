# PostgreSQL connection string for your development database
DATABASE_URL=postgres://username:password@localhost:5432/fitmeat

# JWT signing secrets and expirations
JWT_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# SMTP settings for MailHog in development
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM="FitMeat <no-reply@fitmeat.local>"
APP_URL=http://localhost:4000

# Optional MailHog interface URL
MAILHOG_UI=http://localhost:8025
